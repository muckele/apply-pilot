# Production database
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST.neon.tech/DB?sslmode=require"

# Auth.js / NextAuth
AUTH_SECRET="generate-a-strong-production-secret"
AUTH_URL="https://your-production-domain.com"
NEXTAUTH_URL="https://your-production-domain.com"
APP_BASE_URL="https://your-production-domain.com"
APP_VERSION=""
LOG_LEVEL="info"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AUTH_ALLOWED_EMAILS="muckele7@gmail.com"

# Disable local demo fallback in production.
ALLOW_DEMO_USER="false"
DEFAULT_DEMO_USER_ID="demo-user"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_MOCK_MODE="false"

# Gmail OAuth integration
GMAIL_REDIRECT_URI="https://your-production-domain.com/api/gmail/callback"
GMAIL_SCOPES="https://www.googleapis.com/auth/gmail.readonly"

# Automated job discovery
USAJOBS_API_KEY=""
USAJOBS_USER_AGENT=""
WORKABLE_API_TOKEN=""
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
ADZUNA_COUNTRY="us"
THEIRSTACK_API_KEY=""
THEIRSTACK_POSTED_MAX_AGE_DAYS="30"
SERPAPI_API_KEY=""
SERPAPI_MAX_QUERIES_PER_RUN="3"
JOB_SOURCE_MAX_POSTED_AGE_DAYS="30"
CRON_SECRET="generate-a-random-long-cron-secret"

# Token encryption
TOKEN_ENCRYPTION_KEY=""

# File storage
# Use durable object storage before relying on resume/audio uploads in production.
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB="8"
