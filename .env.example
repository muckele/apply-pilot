# Database
# For Neon, paste the pooled PostgreSQL connection string here.
# It usually looks like:
# postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobmatch_crm?schema=public"
# For Neon migrations, paste the direct/non-pooled connection string here.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/jobmatch_crm?schema=public"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-random-32-byte-secret"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional comma-separated allowlist for personal use.
AUTH_ALLOWED_EMAILS=""
AUTH_ALLOW_PUBLIC_SIGNUPS="false"

# Demo mode lets local API routes use the seeded demo user when no session exists.
# This is ignored in production and should only be enabled for local demos.
ALLOW_DEMO_USER="false"
DEFAULT_DEMO_USER_ID="demo-user"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_MOCK_MODE="true"

# Gmail OAuth integration. Uses readonly access only for search/snippet import.
GMAIL_REDIRECT_URI="http://localhost:3000/api/gmail/callback"
GMAIL_SCOPES="https://www.googleapis.com/auth/gmail.readonly"

# Automated job discovery
# Remotive public API works without credentials.
# USAJOBS requires an API key and a user-agent email registered with USAJOBS.
USAJOBS_API_KEY=""
USAJOBS_USER_AGENT=""
# Workable requires an approved API token for your Workable account.
WORKABLE_API_TOKEN=""
# Adzuna requires an app id and app key from developer.adzuna.com.
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
ADZUNA_COUNTRY="us"
# TheirStack is a licensed paid API and may charge/consume credits per returned job.
THEIRSTACK_API_KEY=""
THEIRSTACK_POSTED_MAX_AGE_DAYS="30"
# SerpApi Google Jobs API. This may charge/consume credits per search.
SERPAPI_API_KEY=""
SERPAPI_MAX_QUERIES_PER_RUN="3"
JOB_SOURCE_MAX_POSTED_AGE_DAYS="30"

# Scheduled discovery
CRON_SECRET="replace-with-a-random-long-secret"
CRON_MAX_SOURCES_PER_RUN="10"
CRON_MIN_SOURCE_INTERVAL_MINUTES="360"
CRON_RUNNING_LOCK_MINUTES="30"

# 32-byte secret, base64 encoded. Used to encrypt OAuth refresh/access tokens.
TOKEN_ENCRYPTION_KEY=""

# File storage
# Use "database" for durable MVP production storage, or "local" for local development.
FILE_STORAGE_DRIVER="local"
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB="8"
MAX_AUDIO_UPLOAD_MB="25"

# App
APP_BASE_URL="http://localhost:3000"
APP_VERSION="local"
LOG_LEVEL="debug"
